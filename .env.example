# Copy to `.env.local` for local development (never commit secrets)

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
# Publishable key for client-side Stripe.js when used (pk_test_... / pk_live_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret from Stripe Dashboard (configure separate endpoints for DSB vs Premium if needed)
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_DSB_EU=
STRIPE_PRICE_ID_DSB_NON_EU=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_ANNUAL_PRICE_ID=
STRIPE_LAUNCH50_COUPON_ID=

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# SMTP (one.com or your provider)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# -----------------------------------------------------------------------------
# Auth and security
# -----------------------------------------------------------------------------
PREMIUM_JWT_SECRET=
CRON_SECRET=
EMAIL_VERIFICATION_SECRET=
DSB_EMAIL_VERIFY_SECRET=
ADMIN_LIVE_PASSWORD=

# -----------------------------------------------------------------------------
# App URLs and support
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://www.arbeidmatch.no
NEXT_PUBLIC_BASE_URL=https://www.arbeidmatch.no
SUPPORT_EMAIL=post@arbeidmatch.no

# -----------------------------------------------------------------------------
# Optional integrations
# -----------------------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
NEXT_PUBLIC_TIKTOK_LIVE_URL=
ATS_BASE_URL=https://ats.arbeidmatch.no
ATS_API_KEY=

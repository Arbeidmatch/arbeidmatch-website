# Copy to `.env.local` for local development (never commit secrets)

NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

SMTP_PASS=
NEXT_PUBLIC_SITE_URL=https://arbeidmatch.no
NEXT_PUBLIC_BASE_URL=https://arbeidmatch.no

# Stripe: DSB guides (create products/prices in Stripe Dashboard; see docs/stripe-setup.md)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_DSB_EU=
STRIPE_PRICE_ID_DSB_NON_EU=

# ArbeidMatch Premium (subscription, Supabase table `premium_subscribers`)
# Create Product "ArbeidMatch Premium" in Stripe with recurring EUR 10/month and EUR 80/year prices,
# coupon LAUNCH50 (50% off, 3 months), then paste ids below. Webhook endpoint: /api/premium/webhook
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_ANNUAL_PRICE_ID=
STRIPE_LAUNCH50_COUPON_ID=
PREMIUM_JWT_SECRET=

# ATS Integration (activate when ATS is ready: see docs/ats-integration.md)
ATS_BASE_URL=https://ats.arbeidmatch.no
ATS_API_KEY=
ATS_API_SECRET=
ATS_WEBHOOK_SECRET=
